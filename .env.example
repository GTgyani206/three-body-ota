# Required for docker compose fastapi service
ADMIN_TOKEN=replace-with-strong-random-token

# Environment selection: development or production
ENV=development

# MQTT broker connection (used by FastAPI/Streamlit)
# Required: broker hostname or service name
MQTT_HOST=mosquitto
# Optional: broker port (1883 plaintext, 8883 TLS)
MQTT_PORT=1883
# Optional: username/password for authenticated brokers
MQTT_USERNAME=
MQTT_PASSWORD=
# Optional: explicit client id (if empty, service default/auto id is used)
MQTT_CLIENT_ID=
# Optional: keepalive seconds for MQTT connection
MQTT_KEEPALIVE=60
# Optional: enable TLS for broker transport (true/false)
# Note: app code currently reads MQTT_USE_TLS; keep both aligned.
MQTT_TLS_ENABLED=false
MQTT_USE_TLS=false

# Optional override for MQTT TLS CA used by app clients
# In development this defaults to /certs/ca.crt
# (MQTT_TLS_CA_CERT is already used by app services.)
MQTT_TLS_CA_CERT=/certs/ca.crt

# Optional alternate mosquitto config file under mosquitto/config/
MOSQUITTO_CONFIG_FILE=mosquitto.conf
