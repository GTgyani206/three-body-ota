# ── WiFi credentials (change these before building!) ──
CONFIG_ESP_WIFI_SSID="P3"
CONFIG_ESP_WIFI_PASSWORD="123456789"

# ── Server / Broker (change to your laptop's LAN IP) ──
CONFIG_FIRMWARE_SERVER_URL="http://10.22.88.26:8000"
CONFIG_MQTT_BROKER_URL="mqtt://10.22.88.26:1883"

# ── Bootloader / System ──
CONFIG_BOOTLOADER_LOG_LEVEL_WARN=y
CONFIG_ESP_SYSTEM_PANIC_PRINT_REBOOT=y

# ── Flash Size ──
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# ── Partition Table ──
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partition.csv"
CONFIG_PARTITION_TABLE_FILENAME="partition.csv"